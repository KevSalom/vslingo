# Copy this file to .env and replace only the values you are authorized to use.
# Leave optional provider credentials blank until live smokes are explicitly approved.
APP_ENV=development
FRONTEND_ORIGIN=http://localhost:4321

# OpenRouter: required for live Writing corrections and the explicit STT/chat smokes.
OPENROUTER_API_KEY=
OPENROUTER_STT_MODEL=openai/whisper-large-v3-turbo
OPENROUTER_LLM_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# AWS Polly: use a dedicated non-root IAM identity with the minimum approved policy.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_POLLY_VOICE_ID=Matthew

# Microsoft Edge Neural: no Azure SDK credential is required.
EDGE_TTS_VOICE=en-US-GuyNeural
PROVIDER_TIMEOUT_SECONDS=30
